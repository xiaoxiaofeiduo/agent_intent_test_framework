# 镜像标签（如需推送到私有 registry，修改为 registry.example.com/project/image:tag）
IMAGE_TAG=agent-intent-test:latest

# 保护设备地址（必填，部署前请修改为实际地址）
DEVICE_URL=

# 保护设备 API Key（如需要）
API_KEY=

# 模型名称
MODEL=mock-agent-intent-model

# 请求超时（秒）
TIMEOUT_SECONDS=30

# 是否默认使用流式响应
DEFAULT_STREAM=false

# 原站对比地址（可选，用于响应对比测试）
ORIGIN_URL=

# 原站 API Key（可选）
ORIGIN_API_KEY=

# 服务端口
APP_PORT=18081
